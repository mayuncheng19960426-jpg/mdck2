<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许用户配置的任意 endpoint 使用明文 HTTP（本地 LLM 等场景） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
